<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:orientation="vertical"
    android:gravity="center">

    <!-- 超时自动停止倒计时进度条 -->
    <ProgressBar
        android:id="@+id/countdown_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:max="120"
        android:progress="120"
        android:progressTint="#FFFFFF"
        android:progressBackgroundTint="#33FFFFFF" />

    <!-- 提示文字 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text='试试说"关闭闹钟"'
        android:textColor="#A0A0A0"
        android:textSize="14sp"
        android:layout_marginTop="60dp" />

    <!-- 时间显示 -->
    <TextView
        android:id="@+id/alarm_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="08:21"
        android:textColor="#FFFFFF"
        android:textSize="96sp"
        android:fontFamily="sans-serif-thin"
        android:letterSpacing="0.02"
        android:layout_marginTop="32dp" />

    <!-- 日期显示 -->
    <TextView
        android:id="@+id/alarm_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="6月11日 星期三"
        android:textColor="#A0A0A0"
        android:textSize="18sp"
        android:layout_marginTop="8dp" />

    <!-- 间隔 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- 标题 -->
    <TextView
        android:id="@+id/alarm_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="闹钟"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold" />

    <!-- 稍后提醒按钮 -->
    <Button
        android:id="@+id/snooze_button"
        android:layout_width="240dp"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/alarm_button_snooze"
        android:text="10 分钟后提醒"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:letterSpacing="0.02" />

    <!-- 间隔 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- 滑动关闭区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="60dp">

        <!-- 滑动条背景 -->
        <LinearLayout
            android:layout_width="300dp"
            android:layout_height="60dp"
            android:background="@drawable/alarm_slider_bg"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="8dp">

            <!-- 左边圆点 -->
            <View
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/alarm_slider_dot" />

            <!-- 中间圆形区域 -->
            <View
                android:id="@+id/slider_center"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/alarm_slider_center"
                android:layout_marginLeft="-10dp"
                android:layout_marginRight="-10dp" />

            <!-- 右边圆点 -->
            <View
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/alarm_slider_dot" />

        </LinearLayout>

        <!-- 提示文字 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="滑动关闭闹铃"
            android:textColor="#A0A0A0"
            android:textSize="14sp"
            android:layout_marginTop="12dp" />

    </LinearLayout>

</LinearLayout>